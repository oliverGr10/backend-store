# ─── BodegaApp Backend — Variables de Entorno ────────────────────────────────
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitees el .env — está en .gitignore.

# ── Entorno ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=cambia-esto-por-un-secret-key-seguro-de-al-menos-32-chars

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # anon key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # service_role key

# ── Base de datos (PostgreSQL directo) ───────────────────────────────────────
# Puedes obtener esta URL desde: Supabase Dashboard → Settings → Database
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Anthropic (IA) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
